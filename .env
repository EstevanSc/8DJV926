# Root environment file for docker-compose and local development
# Copy/edit as needed before running `docker-compose up`.

# Orchestrator
PORT=8081
ORCHESTRATOR_PORT=8081
ORCH_PORT=7000
ENVIRONMENT=development
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Orchestrator QUIC server (for quadtree communication)
ORCHESTRATOR_QUIC_PORT=5000

# Quadtree configuration
QUADTREE_WORLD_SIZE=2048.0
QUADTREE_MAX_CAPACITY=2
QUADTREE_MAX_DEPTH=2
QUADTREE_NEARBY_MARGIN=100.0
QUADTREE_LISTEN_PORT=5000
QUADTREE_ORCHESTRATOR_HOST=orchestrator
QUADTREE_ORCHESTRATOR_PORT=5000
QUADTREE_TICK_MS=50
QUADTREE_AREA_OF_INTEREST_RADIUS=500.0

# Dedicated server defaults
DS_BASE_PORT=7777
DS_PORT=7777
DS_PUBLIC_IP=localhost
DS_ZONE=zone_A

# Scaling and heartbeat (DEPRECATED: orchestrator now listens to quadtree for shard updates)
HOT_SERVERS_MIN=0
HEARTBEAT_TTL_SECONDS=30
SCALER_INTERVAL_SECONDS=5

# Docker spawn settings
GAME_IMAGE=game-server:latest
GAME_NETWORK=game-net
PUBLIC_ADDR=localhost
MAX_PLAYERS=2
ORCH_HOST=orchestrator:7000
RUST_LOG=info
MARGIN=40.0

# Gatekeeper / external services 
SUPABASE_URL= https://asutrpqfngsuokiqvxfc.supabase.co/
SUPABASE_SERVICE_KEY= sb_publishable_S3uaXGUYeWneJUzQDbcckw_ybjJKcKr

# AI Service configuration
AI_SERVICE_BROKER_HOST=broker
AI_SERVICE_BROKER_PORT=7776
AI_SERVICE_SPAWN_FREQUENCY_SECS=10.0
AI_SERVICE_MAX_AI=5
AI_SERVICE_SPAWN_TOP_SHARD_PERCENTAGE=70.0
AI_SERVICE_SPAWN_PADDING=50.0