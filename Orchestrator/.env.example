# HTTP API port
ORCHESTRATOR_PORT=8081
# UDP heartbeat listener port
ORCH_PORT=7000
# Redis port (internal to container, always 6379)
REDIS_PORT=6379
# Dedicated server binary path
DS_BINARY_PATH=/app/mock_server.sh
# Dedicated server starting port
DS_BASE_PORT=7777
# Minimum number of empty servers to maintain
HOT_SERVERS_MIN=2
# Heartbeat TTL in seconds (how long a heartbeat record lives in Redis)
HEARTBEAT_TTL_SECONDS=30
# Scaler loop interval in seconds
SCALER_INTERVAL_SECONDS=5